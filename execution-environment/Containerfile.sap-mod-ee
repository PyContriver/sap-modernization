# sap-mod-ee: ee-supported-rhel9 + pytfe + hashicorp.terraform 2.0 (overwrites bundled 1.x in-place)
FROM 34.205.23.227/ee-supported-rhel9:latest
USER root
ENV PIP_BREAK_SYSTEM_PACKAGES=1

RUN /usr/bin/python3 -m pip install --no-cache-dir boto3 'pytfe>=0.1.5' \
    && /usr/bin/python3 -c "import pytfe; print('pytfe', pytfe.__version__)"

# Overwrite hashicorp.terraform 1.x in the standard collections path AWX always uses
RUN rm -rf /usr/share/ansible/collections/ansible_collections/hashicorp/terraform
COPY .collections-staging/ansible_collections/hashicorp/terraform \
     /usr/share/ansible/collections/ansible_collections/hashicorp/terraform

RUN python3 -c "import json; m=json.load(open('/usr/share/ansible/collections/ansible_collections/hashicorp/terraform/MANIFEST.json')); v=m['collection_info']['version']; assert v.startswith('2.'), f'expected 2.x, got {v}'; print('hashicorp.terraform', v)"
