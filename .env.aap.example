# AAP / Automation Controller API (copy to .env.aap — never commit)
# Used with: source scripts/load-env-aap.sh && ./scripts/bootstrap-aap.sh
#
# Also source your SAP demo secrets from .env (AWS, TF_TOKEN, SSH key path).

# Controller URL (no trailing slash)
CONTROLLER_HOST=https://your-aap.example.com
# OAuth2 token (AAP → Users → your user → Tokens) — preferred
CONTROLLER_OAUTH_TOKEN=
# Or basic auth (if OAuth not used)
# CONTROLLER_USERNAME=admin
# CONTROLLER_PASSWORD=

AAP_ORGANIZATION=Default
AAP_VERIFY_SSL=true

# Optional overrides for object names in AAP
# AAP_CREDENTIAL_AWS_NAME=SAP Mod - AWS
# AAP_CREDENTIAL_SSH_NAME=SAP Mod - Builder SSH
# AAP_CREDENTIAL_HCP_NAME=SAP Mod - HCP Terraform
