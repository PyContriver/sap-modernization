# Copy to .env and fill in real values (never commit .env)
#   cp .env.example .env
#
# Load before playbooks:
#   source scripts/load-env.sh
#   ansible-playbook playbooks/day0-infrastructure.yml

# --- Automation Hub (install hashicorp.terraform) ---
ANSIBLE_GALAXY_SERVER_AUTOMATION_HUB_TOKEN=

# --- HCP Terraform (hashicorp.terraform runs) ---
TF_TOKEN=
HCP_TERRAFORM_ORGANIZATION=REPLACE-org
HCP_TERRAFORM_WORKSPACE=sap-modernization-demo
# Optional — preferred over org+workspace name
HCP_TERRAFORM_WORKSPACE_ID=

# --- AWS API credentials (standard env vars — NOT Terraform "variables") ---
# Used by Ansible on your laptop: preflight, golden AMI (ec2_ami), postflight, etc.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# AWS_SESSION_TOKEN=
AWS_DEFAULT_REGION=us-east-1

# --- ALSO set AWS on the HCP Terraform WORKSPACE (for Terraform runs themselves) ---
# HCP → Workspace → Variables → Environment variables (or AWS dynamic credentials):
#   AWS_ACCESS_KEY_ID, AWS_SECRET_ACCESS_KEY  (or use HCP AWS provider auth)
# Without this, hashicorp.terraform runs fail when applying AWS resources.

# --- Terraform input variables (sent to HCP as run variables via Ansible) ---
# These map to terraform/variables.tf — can be set here OR in group_vars/demo/aws.yml
# Optional — leave unset to auto-pick latest RHEL 9 in AWS_DEFAULT_REGION (Marketplace subscription required)
# BASE_AMI_ID=ami-0abc123def4567890
# Must already exist in AWS_DEFAULT_REGION (EC2 → Key pairs → name column)
SSH_KEY_NAME=your-ec2-keypair
# Private key file for Ansible SSH to builder (chmod 600); auto-detected as ~/.ssh/${SSH_KEY_NAME}.pem if unset
SSH_PRIVATE_KEY_FILE=
# Your public IP/32 for builder SSH (load-env.sh auto-detects if left as example below)
# ALLOWED_SSH_CIDR=203.0.113.0/32

# Optional overrides
# TERRAFORM_DRIVER=hcp
# GOLDEN_AMI_ID=ami-xxxxxxxx
# GOLDEN_IMAGE_METHOD=ansible
