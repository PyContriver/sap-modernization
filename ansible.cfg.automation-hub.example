# Copy snippets into ansible.cfg when installing from Automation Hub (AAP EE build or controller)
#
# 1. Create API token: https://console.redhat.com/ansible/automation-hub/token
# 2. Replace YOUR_AUTOMATION_HUB_TOKEN below

[galaxy]
server_list = automation_hub, release_galaxy

[galaxy_server.automation_hub]
url = https://console.redhat.com/api/automation-hub/content/published/
auth_url = https://sso.redhat.com/auth/realms/redhat-external/protocol/openid-connect/token
token = YOUR_AUTOMATION_HUB_TOKEN

[galaxy_server.release_galaxy]
url = https://galaxy.ansible.com/
ignore_errors = true
